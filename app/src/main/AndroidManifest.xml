<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" /> <!-- Required for Android 12 (API 31) and above -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" /> <!-- Needed if scanning for devices -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/logo_updated"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/logo_updated_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FarmFusion"
        tools:targetApi="31">
        <activity
            android:name=".wheelTestingPage"
            android:exported="false" />
        <activity
            android:name=".rotateWheels"
            android:exported="false" />
        <activity
            android:name=".seeding"
            android:exported="false" />
        <activity
            android:name=".harvesting"
            android:exported="false" />
        <activity
            android:name=".planting"
            android:exported="false" />
        <activity
            android:name=".routing"
            android:exported="false" />
        <activity
            android:name=".fertilizers"
            android:exported="false" />
        <activity
            android:name=".spraying"
            android:exported="false" />
        <activity
            android:name=".weedRemoval"
            android:exported="false" />
        <activity
            android:name=".splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false" />
    </application>

</manifest>